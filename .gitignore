# Obsidian workspace (local only)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/*/data.json

# Auto-synced GitHub issues (regenerated by script)
00-Inbox/GitHub/*.md

# OS
.DS_Store
Thumbs.db
git-error-*

# Secrets — NEVER commit
.env
secrets/
*.token

# Auto-generated runtime artifacts
HYPERFOCUS_ZONE/Hub/Brain-Constellation-Live.md

# Python cache — NEVER commit
__pycache__/
*.pyc
*.pyo
*.pyd

# Generated output — NEVER commit
output/
logs/
*.log
